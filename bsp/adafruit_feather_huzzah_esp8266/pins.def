/**
 * @file pins.def
 * @brief Definicja pinów dla Adafruit Feather HUZZAH ESP8266
 * * Mapowanie na podstawie oficjalnej dokumentacji Adafruit.
 */

/* --- SYSTEMOWE / UART --- */
/* TX (GPIO1) i RX (GPIO3) są zdefiniowane w adapterze UART, 
   tutaj definiujemy piny funkcyjne dla Aktorów */

/* --- DIODY I PRZYCISKI --- */
/* Czerwona dioda LED obok złącza USB (aktywna w stanie NISKIM) */
EV_PIN(EV_PIN_LED_SYSTEM,  0,  EV_PIN_MODE_OUTPUT_OD)

/* Niebieska dioda LED na module ESP-12 (aktywna w stanie NISKIM) */
EV_PIN(EV_PIN_LED_MODULE,  2,  EV_PIN_MODE_OUTPUT_OD)

/* --- MAGISTRALA I2C (Bardzo ważne: inne niż w Atnel!) --- */
/* W Feather HUZZAH I2C domyślnie używa GPIO 4 i 5 */
EV_PIN(EV_PIN_I2C_SDA,     4,  EV_PIN_MODE_I2C)
EV_PIN(EV_PIN_I2C_SCL,     5,  EV_PIN_MODE_I2C)

/* --- MAGISTRALA SPI --- */
EV_PIN(EV_PIN_SPI_SCK,    14,  EV_PIN_MODE_SPI)
EV_PIN(EV_PIN_SPI_MISO,   12,  EV_PIN_MODE_SPI)
EV_PIN(EV_PIN_SPI_MOSI,   13,  EV_PIN_MODE_SPI)

/* --- PINY OGÓLNEGO PRZEZNACZENIA (Feather Header) --- */
EV_PIN(EV_PIN_HUZZAH_G16, 16,  EV_PIN_MODE_INPUT) /* Wake-up pin */
EV_PIN(EV_PIN_HUZZAH_G15, 15,  EV_PIN_MODE_OUTPUT)
EV_PIN(EV_PIN_HUZZAH_G12, 12,  EV_PIN_MODE_INPUT_PULLUP)
EV_PIN(EV_PIN_HUZZAH_G13, 13,  EV_PIN_MODE_INPUT_PULLUP)
EV_PIN(EV_PIN_HUZZAH_G14, 14,  EV_PIN_MODE_INPUT_PULLUP)

/* --- ANALOG --- */
/* Pin A0 (ADC0) - w HUZZAH ma dzielnik napięcia 1/10 
   pozwalający na pomiar napięcia baterii LiPo do 6V */
EV_PIN_ANALOG(EV_PIN_BATTERY_SENSE, 0)
