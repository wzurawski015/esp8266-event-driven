sdk_check() {
  build_sdk_image
  run_in_image \
    "$SDK_IMAGE" \
    sh -lc '
      set -eu
      xtensa-lx106-elf-gcc --version | head -n 1
      python3 --version
      python3 -c "import pip, serial, setuptools; print(\"python_env=ok pip=%s pyserial=%s setuptools=%s\" % (pip.__version__, getattr(serial, \"VERSION\", getattr(serial, \"__version__\", \"unknown\")), setuptools.__version__))"
      make --version | head -n 1
      printf "IDF_PATH=%s\n" "$IDF_PATH"
      test -f "$IDF_PATH/make/project.mk"
      test -f "$IDF_PATH/export.sh"
      git -C "$IDF_PATH" rev-parse --is-inside-work-tree >/dev/null
    '
}

