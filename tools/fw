#!/usr/bin/env sh
set -eu

ROOT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
DOCKER_BIN="${DOCKER_BIN:-docker}"

sdk_default_monitor_baud() {
  case "$1" in
    adapters/esp8266_rtos_sdk/targets/esp8266_generic_dev|\
    adapters/esp8266_rtos_sdk/targets/atnel_air_esp_motherboard|\
    adapters/esp8266_rtos_sdk/targets/atnel_air_esp_motherboard_i2c_hil|\
    adapters/esp8266_rtos_sdk/targets/atnel_air_esp_motherboard_onewire_hil)
      printf '%s\n' '115200'
      ;;
    *)
      printf '%s\n' '74880'
      ;;
  esac
}

HOST_IMAGE="${FW_HOST_IMAGE:-esp8266-event-driven-host:local}"
DOCS_IMAGE="${FW_DOCS_IMAGE:-esp8266-event-driven-docs:local}"
SDK_IMAGE="${FW_SDK_IMAGE:-esp8266-event-driven-sdk:local}"

RUN_USER="${FW_RUN_USER:-$(id -u):$(id -g)}"
SDK_PROJECT_DIR_REL="${FW_SDK_PROJECT_DIR:-adapters/esp8266_rtos_sdk/targets/esp8266_generic_dev}"
HIL_I2C_PROJECT_DIR_REL="${FW_HIL_I2C_PROJECT_DIR:-adapters/esp8266_rtos_sdk/targets/atnel_air_esp_motherboard_i2c_hil}"
HIL_I2C_MONITOR_TIMEOUT_S="${FW_HIL_I2C_TIMEOUT_S:-180}"
HIL_ONEWIRE_PROJECT_DIR_REL="${FW_HIL_ONEWIRE_PROJECT_DIR:-adapters/esp8266_rtos_sdk/targets/atnel_air_esp_motherboard_onewire_hil}"
HIL_ONEWIRE_MONITOR_TIMEOUT_S="${FW_HIL_ONEWIRE_TIMEOUT_S:-240}"
SDK_SERIAL_PORT="${FW_ESPPORT:-${ESPPORT:-}}"
SDK_MONITOR_BAUD="${FW_MONITOR_BAUD:-${MONITORBAUD:-$(sdk_default_monitor_baud "$SDK_PROJECT_DIR_REL")}}"
SDK_FLASH_BEFORE="${FW_FLASH_BEFORE:-default_reset}"
SDK_FLASH_AFTER="${FW_FLASH_AFTER:-hard_reset}"
SDK_FLASH_RETRIES="${FW_FLASH_RETRIES:-3}"
SDK_FLASH_RETRY_DELAY_S="${FW_FLASH_RETRY_DELAY_S:-1}"

