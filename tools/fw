  fi
}

sdk_check() {
  build_sdk_image
  run_in_image \
    "$SDK_IMAGE" \
    sh -lc '
      set -eu
      xtensa-lx106-elf-gcc --version | head -n 1
      python3 --version
      python3 -c "import pkg_resources; print(\"pkg_resources=ok\")"
      make --version | head -n 1
      printf "IDF_PATH=%s\n" "$IDF_PATH"
      test -f "$IDF_PATH/make/project.mk"
      test -f "$IDF_PATH/export.sh"
      git -C "$IDF_PATH" rev-parse --is-inside-work-tree >/dev/null
    '
}

sdk_defconfig() {
  run_in_sdk \
    sh -lc '
      set -eu
      make -C "$EV_SDK_PROJECT" SDKCONFIG_DEFAULTS=sdkconfig.defaults defconfig
    '
}

sdk_build() {
  run_in_sdk \
    sh -lc '
      set -eu
      if [ ! -f "$EV_SDK_PROJECT/sdkconfig" ]; then
        make -C "$EV_SDK_PROJECT" SDKCONFIG_DEFAULTS=sdkconfig.defaults defconfig
      fi
      jobs=$(getconf _NPROCESSORS_ONLN 2>/dev/null || echo 1)
      make -C "$EV_SDK_PROJECT" -j"$jobs"
    '
}

sdk_menuconfig() {
  run_in_sdk_it \
    sh -lc '
      set -eu
      if [ ! -f "$EV_SDK_PROJECT/sdkconfig" ]; then
        make -C "$EV_SDK_PROJECT" SDKCONFIG_DEFAULTS=sdkconfig.defaults defconfig
      fi
      make -C "$EV_SDK_PROJECT" menuconfig
    '
}

sdk_flash_common() {
  run_in_sdk_with_device     sh -lc '
      set -eu
      if [ ! -f "$EV_SDK_PROJECT/sdkconfig" ]; then
        make -C "$EV_SDK_PROJECT" SDKCONFIG_DEFAULTS=sdkconfig.defaults defconfig
      fi

      attempt=1
      status=1

      while [ "$attempt" -le "$FLASH_RETRIES" ]; do
        log_file=$(mktemp)

        if make -C "$EV_SDK_PROJECT" \
            ESPPORT="$ESPPORT" \
            ESPTOOLPY_BEFORE="$FLASH_BEFORE" \
            ESPTOOLPY_AFTER="$FLASH_AFTER" \
            flash >"$log_file" 2>&1; then
          cat "$log_file"
          rm -f "$log_file"
          exit 0
        fi

        status=$?
        cat "$log_file" >&2

        if grep -Eq "setDTR|setRTS|TIOCMBIC|TIOCMBIS|Input/output error|Errno 5" "$log_file"; then
          echo "note: serial modem-control toggling failed on $ESPPORT (attempt $attempt/$FLASH_RETRIES)." >&2
          echo "note: this is a known Docker/WSL2 USB-serial edge case." >&2
          echo "note: if retries do not help, use ./tools/fw sdk-flash-manual" >&2
          echo "note: after putting the board into ROM bootloader mode manually." >&2
        fi

        rm -f "$log_file"

        if [ "$attempt" -ge "$FLASH_RETRIES" ]; then
          exit "$status"
        fi

        echo "note: retrying flash in ${FLASH_RETRY_DELAY_S}s..." >&2
        sleep "$FLASH_RETRY_DELAY_S"
        attempt=$((attempt + 1))
      done

      exit "$status"
    '
}

sdk_flash() {
  sdk_flash_common
}

sdk_flash_manual() {
  echo "note: sdk-flash-manual disables DTR/RTS auto-reset." >&2
  echo "note: put the board into ROM bootloader mode manually before flashing." >&2
  FLASH_BEFORE=no_reset FLASH_AFTER=no_reset sdk_flash_common
}


sdk_monitor() {
  run_in_sdk_with_device_it \
    sh -lc '
      set -eu
      test -f "$EV_SDK_PROJECT/sdkconfig" || {
        echo "error: sdkconfig missing, run ./tools/fw sdk-defconfig or ./tools/fw sdk-build first" >&2
        exit 1
      }
      echo "note: if interactive monitor fails under Docker/WSL2, use ./tools/fw sdk-simple-monitor" >&2
      make -C "$EV_SDK_PROJECT" ESPPORT="$ESPPORT" MONITORBAUD="$MONITORBAUD" monitor
    '
}

sdk_simple_monitor() {
  run_in_sdk_with_device_i \
    sh -lc '
      set -eu
      test -f "$EV_SDK_PROJECT/sdkconfig" || {
        echo "error: sdkconfig missing, run ./tools/fw sdk-defconfig or ./tools/fw sdk-build first" >&2
        exit 1
      }
      printf "simple serial monitor: %s @ %s\n" "$ESPPORT" "$MONITORBAUD" >&2
      printf "quit with Ctrl+C\n" >&2
      stty -F "$ESPPORT" "$MONITORBAUD" raw -echo -echoe -echok -echoctl -echoke
      exec stdbuf -o0 cat "$ESPPORT"
    '
}

cmd="${1:-}"

case "$cmd" in
  host-image)
    build_host_image
    ;;
  docs-image)
    build_docs_image
    ;;
  sdk-image)
    build_sdk_image
    ;;
  host-test)
    build_host_image
    run_in_image "$HOST_IMAGE" make host-test
    ;;
  docgen)
    build_host_image
    run_in_image "$HOST_IMAGE" make docgen
    ;;
  docs)
    build_docs_image
    run_in_image "$DOCS_IMAGE" make docs
    ;;
  clean)
    build_host_image
    run_in_image "$HOST_IMAGE" make clean
    ;;
  shell-host)
    build_host_image
    run_in_image_it "$HOST_IMAGE" sh
    ;;
  shell-docs)
    build_docs_image
    run_in_image_it "$DOCS_IMAGE" sh
    ;;
  shell-sdk)
    require_sdk_project
    build_sdk_image
    run_in_sdk_it sh
    ;;
  sdk-check)
    sdk_check
    ;;
  sdk-defconfig)
    sdk_defconfig
    ;;
  sdk-menuconfig)
    sdk_menuconfig
    ;;
  sdk-build)
    sdk_build
    ;;
  sdk-clean-target)
    sdk_clean_target
    ;;
  sdk-distclean)
    sdk_distclean
    ;;
  sdk-flash)
    sdk_flash
    ;;
  sdk-flash-manual)
    sdk_flash_manual
    ;;
  sdk-monitor)
    sdk_monitor
    ;;
  sdk-simple-monitor)
    sdk_simple_monitor
    ;;
  *)
    usage
    exit 1
    ;;
esac
