      -v "$ROOT_DIR:/work" \
      -w /work \
      "$SDK_IMAGE" \
      env \
      EV_SDK_PROJECT="$SDK_PROJECT_DIR_REL" \
      ESPPORT="$SDK_SERIAL_PORT" \
      MONITORBAUD="$SDK_MONITOR_BAUD" \
      FLASH_BEFORE="${FLASH_BEFORE:-$SDK_FLASH_BEFORE}" \
      FLASH_AFTER="${FLASH_AFTER:-$SDK_FLASH_AFTER}" \
      FLASH_RETRIES="${FLASH_RETRIES:-$SDK_FLASH_RETRIES}" \
      FLASH_RETRY_DELAY_S="${FLASH_RETRY_DELAY_S:-$SDK_FLASH_RETRY_DELAY_S}" \
      "$@"
  else
    "$DOCKER_BIN" run --rm -it \
      --user "$RUN_USER" \
      --device "$SDK_SERIAL_PORT:$SDK_SERIAL_PORT" \
      -v "$ROOT_DIR:/work" \
      -w /work \
      "$SDK_IMAGE" \
      env \
      EV_SDK_PROJECT="$SDK_PROJECT_DIR_REL" \
      ESPPORT="$SDK_SERIAL_PORT" \
      MONITORBAUD="$SDK_MONITOR_BAUD" \
      FLASH_BEFORE="${FLASH_BEFORE:-$SDK_FLASH_BEFORE}" \
      FLASH_AFTER="${FLASH_AFTER:-$SDK_FLASH_AFTER}" \
      FLASH_RETRIES="${FLASH_RETRIES:-$SDK_FLASH_RETRIES}" \
      FLASH_RETRY_DELAY_S="${FLASH_RETRY_DELAY_S:-$SDK_FLASH_RETRY_DELAY_S}" \
