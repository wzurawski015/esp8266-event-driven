#!/usr/bin/env sh
set -eu

ROOT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
DOCKER_BIN="${DOCKER_BIN:-docker}"

HOST_IMAGE="${FW_HOST_IMAGE:-esp8266-event-driven-host:local}"
DOCS_IMAGE="${FW_DOCS_IMAGE:-esp8266-event-driven-docs:local}"
SDK_IMAGE="${FW_SDK_IMAGE:-esp8266-event-driven-sdk:local}"

RUN_USER="${FW_RUN_USER:-$(id -u):$(id -g)}"
SDK_PROJECT_DIR_REL="${FW_SDK_PROJECT_DIR:-adapters/esp8266_rtos_sdk/targets/esp8266_generic_dev}"
SDK_SERIAL_PORT="${FW_ESPPORT:-${ESPPORT:-/dev/ttyUSB0}}"
SDK_MONITOR_BAUD="${FW_MONITOR_BAUD:-${MONITORBAUD:-74880}}"
SDK_FLASH_BEFORE="${FW_FLASH_BEFORE:-default_reset}"
SDK_FLASH_AFTER="${FW_FLASH_AFTER:-hard_reset}"
SDK_FLASH_RETRIES="${FW_FLASH_RETRIES:-3}"
SDK_FLASH_RETRY_DELAY_S="${FW_FLASH_RETRY_DELAY_S:-1}"

usage() {
  cat <<'USAGE'
Usage:
  ./tools/fw host-image
  ./tools/fw docs-image
  ./tools/fw sdk-image

  ./tools/fw host-test
  ./tools/fw docgen
  ./tools/fw docs
  ./tools/fw clean

  ./tools/fw shell-host
  ./tools/fw shell-docs
  ./tools/fw shell-sdk

  ./tools/fw sdk-check
  ./tools/fw sdk-defconfig
  ./tools/fw sdk-menuconfig
  ./tools/fw sdk-build
  ./tools/fw sdk-clean-target
  ./tools/fw sdk-distclean
  ./tools/fw sdk-flash
  ./tools/fw sdk-flash-manual
  ./tools/fw sdk-monitor
  ./tools/fw sdk-simple-monitor

Notes:
  - All developer-facing validation runs inside Docker by default.
  - Containers write back to the bind mount using the caller UID:GID.
  - Set DOCKER_BIN, FW_HOST_IMAGE, FW_DOCS_IMAGE, FW_SDK_IMAGE, FW_RUN_USER,
    FW_SDK_PROJECT_DIR, FW_ESPPORT, FW_MONITOR_BAUD, FW_FLASH_BEFORE,
    FW_FLASH_AFTER, FW_FLASH_RETRIES, or FW_FLASH_RETRY_DELAY_S to override defaults.
USAGE
}

require_docker() {
  command -v "$DOCKER_BIN" >/dev/null 2>&1 || {
    echo "error: docker binary not found: $DOCKER_BIN" >&2
    exit 1
  }
}

require_sdk_project() {
  if [ ! -f "$ROOT_DIR/$SDK_PROJECT_DIR_REL/Makefile" ]; then
    echo "error: SDK project not found at $ROOT_DIR/$SDK_PROJECT_DIR_REL" >&2
    echo "set FW_SDK_PROJECT_DIR to a valid relative project path" >&2
    exit 1
  fi
}

require_serial_port() {
  if [ ! -e "$SDK_SERIAL_PORT" ]; then
    echo "error: serial device not found: $SDK_SERIAL_PORT" >&2
    echo "set FW_ESPPORT to the host serial device, for example /dev/ttyUSB0" >&2
    exit 1
  fi
}

build_host_image() {
  require_docker
  "$DOCKER_BIN" build \
    -f "$ROOT_DIR/docker/Dockerfile.host" \
    -t "$HOST_IMAGE" \
    "$ROOT_DIR"
}

build_docs_image() {
  require_docker
  "$DOCKER_BIN" build \
    -f "$ROOT_DIR/docker/Dockerfile.docs" \
    -t "$DOCS_IMAGE" \
    "$ROOT_DIR"
}

build_sdk_image() {
  require_docker
  "$DOCKER_BIN" build \
    -f "$ROOT_DIR/docker/Dockerfile.sdk" \
    -t "$SDK_IMAGE" \
    "$ROOT_DIR"
}

run_in_image() {
  image="$1"
  shift
  "$DOCKER_BIN" run --rm \
    --user "$RUN_USER" \
    -v "$ROOT_DIR:/work" \
    -w /work \
    "$image" \
    "$@"
}

run_in_image_it() {
  image="$1"
  shift
  "$DOCKER_BIN" run --rm -it \
    --user "$RUN_USER" \
    -v "$ROOT_DIR:/work" \
    -w /work \
    "$image" \
    "$@"
}

run_in_sdk() {
  require_sdk_project
  build_sdk_image
  run_in_image \
    "$SDK_IMAGE" \
    env \
    EV_SDK_PROJECT="$SDK_PROJECT_DIR_REL" \
    ESPPORT="$SDK_SERIAL_PORT" \
    MONITORBAUD="$SDK_MONITOR_BAUD" \
    "$@"
}

run_in_sdk_it() {
  require_sdk_project
  build_sdk_image
  run_in_image_it \
    "$SDK_IMAGE" \
    env \
    EV_SDK_PROJECT="$SDK_PROJECT_DIR_REL" \
    ESPPORT="$SDK_SERIAL_PORT" \
    MONITORBAUD="$SDK_MONITOR_BAUD" \
    "$@"
}

run_in_sdk_with_device() {
  require_sdk_project
  require_serial_port
  build_sdk_image

  serial_gid=$(stat -c '%g' "$SDK_SERIAL_PORT" 2>/dev/null || true)

  if [ -n "$serial_gid" ]; then
    "$DOCKER_BIN" run --rm \
      --user "$RUN_USER" \
      --group-add "$serial_gid" \
      --device "$SDK_SERIAL_PORT:$SDK_SERIAL_PORT" \
      -v "$ROOT_DIR:/work" \
      -w /work \
      "$SDK_IMAGE" \
      env \
      EV_SDK_PROJECT="$SDK_PROJECT_DIR_REL" \
      ESPPORT="$SDK_SERIAL_PORT" \
      MONITORBAUD="$SDK_MONITOR_BAUD" \
      FLASH_BEFORE="${FLASH_BEFORE:-$SDK_FLASH_BEFORE}" \
      FLASH_AFTER="${FLASH_AFTER:-$SDK_FLASH_AFTER}" \
      FLASH_RETRIES="${FLASH_RETRIES:-$SDK_FLASH_RETRIES}" \
      FLASH_RETRY_DELAY_S="${FLASH_RETRY_DELAY_S:-$SDK_FLASH_RETRY_DELAY_S}" \
      "$@"
  else
    "$DOCKER_BIN" run --rm \
      --user "$RUN_USER" \
      --device "$SDK_SERIAL_PORT:$SDK_SERIAL_PORT" \
      -v "$ROOT_DIR:/work" \
      -w /work \
      "$SDK_IMAGE" \
      env \
      EV_SDK_PROJECT="$SDK_PROJECT_DIR_REL" \
      ESPPORT="$SDK_SERIAL_PORT" \
      MONITORBAUD="$SDK_MONITOR_BAUD" \
      FLASH_BEFORE="${FLASH_BEFORE:-$SDK_FLASH_BEFORE}" \
      FLASH_AFTER="${FLASH_AFTER:-$SDK_FLASH_AFTER}" \
      FLASH_RETRIES="${FLASH_RETRIES:-$SDK_FLASH_RETRIES}" \
      FLASH_RETRY_DELAY_S="${FLASH_RETRY_DELAY_S:-$SDK_FLASH_RETRY_DELAY_S}" \
      "$@"
  fi
}

