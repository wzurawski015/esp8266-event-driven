}

require_docker() {
  command -v "$DOCKER_BIN" >/dev/null 2>&1 || {
    echo "error: docker binary not found: $DOCKER_BIN" >&2
    exit 1
  }
}

require_sdk_project() {
  if [ ! -f "$ROOT_DIR/$SDK_PROJECT_DIR_REL/Makefile" ]; then
    echo "error: SDK project not found at $ROOT_DIR/$SDK_PROJECT_DIR_REL" >&2
    echo "set FW_SDK_PROJECT_DIR to a valid relative project path" >&2
    exit 1
  fi
}

require_sdkconfig_file() {
  require_sdk_project
  if [ ! -f "$ROOT_DIR/$SDK_PROJECT_DIR_REL/sdkconfig" ]; then
    echo "error: sdkconfig missing for $SDK_PROJECT_DIR_REL" >&2
    echo "run ./tools/fw sdk-defconfig or ./tools/fw sdk-build first" >&2
    exit 1
  fi
}

serial_port_candidates() {
  found=0
  for path in /dev/ttyUSB* /dev/ttyACM*; do
    if [ -e "$path" ]; then
      printf '%s\n' "$path"
      found=1
    fi
  done
  [ "$found" -eq 1 ]
}

resolve_serial_port() {
  if [ -n "$SDK_SERIAL_PORT" ]; then
    return 0
  fi

  candidates=$(serial_port_candidates || true)
  count=$(printf '%s\n' "$candidates" | sed '/^$/d' | wc -l | tr -d '[:space:]')

  case "$count" in
    1)
      SDK_SERIAL_PORT=$(printf '%s\n' "$candidates" | sed -n '1p')
      return 0
      ;;
    0)
      echo "error: no serial device found under /dev/ttyUSB* or /dev/ttyACM*" >&2
      echo "use ./tools/fw sdk-ports to inspect visible serial devices" >&2
      echo "or set FW_ESPPORT explicitly" >&2
      return 1
      ;;
    *)
      echo "error: multiple serial devices found and FW_ESPPORT is not set" >&2
      printf '%s\n' "$candidates" >&2
      echo "use ./tools/fw sdk-port-resolve only when exactly one candidate should exist" >&2
      echo "or set FW_ESPPORT explicitly" >&2
      return 1
      ;;
  esac
}

sdk_ports() {
  if ! serial_port_candidates; then
    echo "error: no serial device found under /dev/ttyUSB* or /dev/ttyACM*" >&2
    exit 1
  fi
}

sdk_port_resolve() {
  require_serial_port
  printf '%s\n' "$SDK_SERIAL_PORT"
}

require_serial_port() {
  resolve_serial_port || exit 1
  if [ ! -e "$SDK_SERIAL_PORT" ]; then
    echo "error: serial device not found: $SDK_SERIAL_PORT" >&2
    echo "use ./tools/fw sdk-ports to inspect visible serial devices" >&2
    echo "or set FW_ESPPORT explicitly" >&2
    exit 1
  fi
}

build_host_image() {
  require_docker
  "$DOCKER_BIN" build \
    -f "$ROOT_DIR/docker/Dockerfile.host" \
    -t "$HOST_IMAGE" \
    "$ROOT_DIR"
}

build_docs_image() {
  require_docker
  "$DOCKER_BIN" build \
    -f "$ROOT_DIR/docker/Dockerfile.docs" \
    -t "$DOCS_IMAGE" \
    "$ROOT_DIR"
}

build_sdk_image() {
  require_docker
  "$DOCKER_BIN" build \
    -f "$ROOT_DIR/docker/Dockerfile.sdk" \
    -t "$SDK_IMAGE" \
    "$ROOT_DIR"
}

run_in_image() {
  image="$1"
  shift
  "$DOCKER_BIN" run --rm \
    --user "$RUN_USER" \
    -v "$ROOT_DIR:/work" \
    -w /work \
    "$image" \
    "$@"
}

run_in_image_it() {
  image="$1"
  shift
  "$DOCKER_BIN" run --rm -it \
    --user "$RUN_USER" \
    -v "$ROOT_DIR:/work" \
    -w /work \
    "$image" \
    "$@"
}

run_in_sdk() {
  require_sdk_project
  build_sdk_image
  run_in_image \
    "$SDK_IMAGE" \
    env \
    EV_SDK_PROJECT="$SDK_PROJECT_DIR_REL" \
    ESPPORT="$SDK_SERIAL_PORT" \
    MONITORBAUD="$SDK_MONITOR_BAUD" \
    "$@"
}

run_in_sdk_it() {
  require_sdk_project
  build_sdk_image
  run_in_image_it \
    "$SDK_IMAGE" \
