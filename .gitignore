# Professional .gitignore for the esp8266-event-driven repository.
#
# Design choices:
# - repository-specific generated paths are root-anchored,
# - SDK target artifacts are ignored at their source,
# - empty log directories are kept intentionally via .gitkeep.

# -----------------------------------------------------------------------------
# Project-generated outputs
# -----------------------------------------------------------------------------

# Top-level build / packaging outputs
/build/
/out/
/coverage/
/dist/
/htmlcov/

# ESP8266 RTOS SDK target-local generated state
/adapters/esp8266_rtos_sdk/targets/*/build/
/adapters/esp8266_rtos_sdk/targets/*/sdkconfig
/adapters/esp8266_rtos_sdk/targets/*/sdkconfig.old

# Generated documentation
/docs/generated/*
!/docs/generated/.gitkeep

# Runtime logs and captures
/log/*
!/log/.gitkeep
/logs/*
!/logs/.gitkeep

# -----------------------------------------------------------------------------
# Native / embedded build artifacts
# -----------------------------------------------------------------------------

*.o
*.obj
*.lo
*.la
*.a
*.so
*.so.*
*.dylib
*.dll
*.exe
*.out

# Coverage / profiling / sanitizer outputs
*.gcda
*.gcno
*.gcov
.coverage
.coverage.*

# -----------------------------------------------------------------------------
# Tooling and local developer environment
# -----------------------------------------------------------------------------

compile_commands.json
.cache/
.clangd/
.vscode/
.idea/
.vs/

# Python / tooling caches
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/

# C / C++ navigation databases
tags
TAGS
cscope.*

# -----------------------------------------------------------------------------
# Editor / OS noise
# -----------------------------------------------------------------------------

*~
*.swp
*.swo
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
Desktop.ini

