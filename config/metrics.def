// Metric catalog single source of truth.
//
// Format:
// EV_METRIC(METRIC_ID, KIND, "summary")

EV_METRIC(EV_METRIC_POST_OK, counter, "Successful event posts")
EV_METRIC(EV_METRIC_POST_DROPPED, counter, "Dropped events")
EV_METRIC(EV_METRIC_MAILBOX_HIGH_WATER, gauge, "Highest observed mailbox usage")
EV_METRIC(EV_METRIC_POOL_HIGH_WATER, gauge, "Highest observed memory pool usage")

EV_METRIC(EV_METRIC_DELIVERY_ATTEMPTED, counter, "Attempted actor-registry deliveries")
EV_METRIC(EV_METRIC_DELIVERY_OK, counter, "Successful actor-registry deliveries")
EV_METRIC(EV_METRIC_DELIVERY_FAILED, counter, "Failed actor-registry deliveries")
EV_METRIC(EV_METRIC_ACTOR_ENQUEUED, counter, "Messages accepted into actor mailboxes")
EV_METRIC(EV_METRIC_ACTOR_HANDLER_ERRORS, counter, "Actor handler failures")
EV_METRIC(EV_METRIC_ACTOR_PENDING_HIGH_WATER, gauge, "Highest observed pending count per actor runtime")
EV_METRIC(EV_METRIC_ACTOR_PUMP_CALLS, counter, "Bounded drain invocations per actor runtime")
EV_METRIC(EV_METRIC_ACTOR_PUMP_BUDGET_HITS, counter, "Bounded drain runs that stopped because budget was exhausted")
EV_METRIC(EV_METRIC_DOMAIN_PUMP_CALLS, counter, "Cooperative domain-pump invocations")
EV_METRIC(EV_METRIC_DOMAIN_PUMP_EMPTY, counter, "Cooperative domain-pump runs with no pending work")
EV_METRIC(EV_METRIC_DOMAIN_PUMP_BUDGET_HITS, counter, "Cooperative domain-pump runs that exhausted the global budget")
