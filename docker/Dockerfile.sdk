FROM ubuntu:24.04@sha256:d1e2e92c075e5ca139d51a140fff46f84315c0fdce203eab2807c7e495eff4f9

ARG DEBIAN_FRONTEND=noninteractive
ARG ESP8266_RTOS_SDK_REF=v3.4
ARG LX106_TOOLCHAIN_URL=https://dl.espressif.com/dl/xtensa-lx106-elf-gcc8_4_0-esp-2020r3-linux-amd64.tar.gz
ARG TINYDTLS_MIRROR_URL=https://github.com/eclipse-tinydtls/tinydtls.git

RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    build-essential \
    ca-certificates \
    ccache \
    cmake \
    file \
    flex \
    bison \
    gawk \
    git \
    gperf \
    libffi-dev \
    libncurses-dev \
    libssl-dev \
    make \
    ninja-build \
    patch \
    python-is-python3 \
    python3 \
    python3-pip \
    python3-serial \
    python3-venv \
    tar \
    unzip \
    wget \
    xz-utils \
    && rm -rf /var/lib/apt/lists/*

RUN mkdir -p /opt/esp /tmp/toolchain \
    && wget -O /tmp/toolchain/lx106.tar.gz "$LX106_TOOLCHAIN_URL" \
    && tar -xzf /tmp/toolchain/lx106.tar.gz -C /opt/esp \
    && rm -rf /tmp/toolchain

COPY tools/patches/ /tmp/ev-sdk-patches/

# Upstream ESP8266_RTOS_SDK v3.4 still references the retired Eclipse tinydtls
# URL inside a nested libcoap submodule. Rewrite that exact URL to the active
# GitHub mirror before recursive submodule checkout so sdk-image remains
# reproducible.
RUN git config --global advice.detachedHead false \
    && git config --global \
       url."$TINYDTLS_MIRROR_URL".insteadOf \
       "https://git.eclipse.org/r/tinydtls/org.eclipse.tinydtls" \
    && git clone --depth 1 --branch "$ESP8266_RTOS_SDK_REF" \
       https://github.com/espressif/ESP8266_RTOS_SDK.git /opt/esp/ESP8266_RTOS_SDK \
    && cd /opt/esp/ESP8266_RTOS_SDK \
    && git submodule update --init --recursive \
    && for p in /tmp/ev-sdk-patches/*.patch; do \
           [ -f "$p" ] || continue; \
           patch -p1 < "$p"; \
       done \
    && rm -rf /tmp/ev-sdk-patches \
    && git config --system --add safe.directory /opt/esp/ESP8266_RTOS_SDK

RUN python3 -m venv /opt/esp/python-env \
    && /opt/esp/python-env/bin/pip install --upgrade pip wheel \
    && /opt/esp/python-env/bin/pip install "setuptools<82" \
    && /opt/esp/python-env/bin/pip install -r /opt/esp/ESP8266_RTOS_SDK/requirements.txt \
    && /opt/esp/python-env/bin/pip install --upgrade "setuptools<82" \
    && /opt/esp/python-env/bin/python3 -c "import pip, serial, setuptools"

ENV IDF_PATH=/opt/esp/ESP8266_RTOS_SDK
ENV PATH=/opt/esp/python-env/bin:/opt/esp/xtensa-lx106-elf/bin:$PATH

WORKDIR /work
CMD ["bash"]
